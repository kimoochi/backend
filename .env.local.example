# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — NEVER commit real keys or connection strings.

# ---------------------------------------------------------------------------
# Option A — your own free Supabase project (https://supabase.com), no Docker
# ---------------------------------------------------------------------------
# Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Settings -> Database -> Connection string -> URI
# (used by `pnpm db:reset` and by the test suite)
DATABASE_URL=

# ---------------------------------------------------------------------------
# Option B — local Supabase (requires the Supabase CLI + Docker)
# Run `supabase start`, then use the values it prints:
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key printed by `supabase start`>
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
